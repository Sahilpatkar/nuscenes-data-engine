# Copy to `.env` and adjust. Loaded by src/nuscenes_data_engine/config.py.

# --- nuScenes source data (read-only, not vendored into the repo) ---
NUSCENES_DATAROOT=/data/ggare/datasets/nuscenes
NUSCENES_VERSION=v1.0-trainval

# --- Pipeline output locations (DVC-tracked, Phase 1) ---
DATA_DIR=./data
PROCESSED_DIR=./data/processed

# --- MinIO (local S3-compatible object store; DVC remote) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nuscenes-data-engine

# --- MLflow tracking server (Phase 2) ---
MLFLOW_TRACKING_URI=http://localhost:5000
