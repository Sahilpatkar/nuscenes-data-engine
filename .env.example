# Copy to `.env` and adjust. Loaded by src/nuscenes_data_engine/config.py.
#
# Topology: this GPU server runs compute only (ingest/train/evaluate) and writes plain
# files. MinIO + the MLflow server live on the LOCAL INFRA MACHINE. The defaults below are
# the no-infra path (file-based MLflow); point them at the infra host only if reachable.

# --- nuScenes source data (read-only, not vendored into the repo) ---
NUSCENES_DATAROOT=/data/ggare/datasets/nuscenes
NUSCENES_VERSION=v1.0-trainval

# --- Pipeline output locations (produced here, synced to the infra machine) ---
DATA_DIR=./data
PROCESSED_DIR=./data/processed

# --- MinIO / DVC remote (runs on the LOCAL INFRA MACHINE) ---
# Used from the infra machine for `dvc push`/`pull`; the GPU server does not push.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nuscenes-data-engine

# --- MLflow ---
# Server default: local SQLite backend (no MLflow server needed; unlocks the registry).
# Sync ./mlruns (db + artifacts) to the infra machine, or point at its MLflow server,
# e.g. http://<infra-host>:5000.
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# --- Weights & Biases (cloud tracking; complements MLflow) ---
# Get your key at https://wandb.ai/authorize, then set it here (or run `uv run wandb login`).
WANDB_API_KEY=
WANDB_ENTITY=            # your W&B username or team (blank = your default entity)
WANDB_PROJECT=nuscenes-data-engine
WANDB_MODE=online        # online | offline (log to ./wandb, sync later) | disabled

# --- Serving (Phase 4) ---
# The API serves models:/<SERVING_MODEL_NAME>@<SERVING_MODEL_ALIAS> from the registry.
# SERVING_WEIGHTS (a local .pt path) bypasses the registry — dev/test without mlruns/.
SERVING_MODEL_NAME=nuscenes-yolo-detector
SERVING_MODEL_ALIAS=production
SERVING_IMGSZ=960
SERVING_CONF=0.25
SERVING_DEVICE=cpu       # cpu on the infra machine; 0 for a GPU
SERVING_WEIGHTS=         # e.g. weights/yolov8n.pt (blank = load from the registry)
API_URL=http://localhost:8000   # where the Streamlit demo finds the API
