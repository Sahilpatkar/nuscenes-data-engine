# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv
.DS_Store

# Caches / coverage
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Env / secrets
.env

# Logs
*.log

# nuScenes raw data is read from /data/ggare/datasets/nuscenes — never vendored.
/data/raw/*
!/data/raw/.gitkeep
# Produced Parquet is compute output on this GPU server; it is rsynced to the infra
# machine and DVC-tracked there — never git-committed from here. The *.dvc pointer files
# (created on the infra machine by `dvc add`) ARE committed.
/data/processed/*.parquet
!/data/processed/*.dvc

# ML / training artifacts (generated, large binaries)
mlruns/
mlartifacts/
wandb/
runs/
*.mp4
*.safetensors
*.pt
*.onnx

# Great Expectations local uncommitted bits
gx/uncommitted/
