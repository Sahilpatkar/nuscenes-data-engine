# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv
.DS_Store

# Caches / coverage
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Env / secrets
.env

# Logs
*.log

# nuScenes raw data is read from /data/ggare/datasets/nuscenes — never vendored.
/data/raw/*
!/data/raw/.gitkeep
# data/processed/ is managed by DVC: `dvc add` writes a local .gitignore there for the
# actual data files, while the *.dvc pointer files ARE committed to git.
!/data/processed/*.dvc

# ML / training artifacts (generated, large binaries)
mlruns/
mlartifacts/
wandb/
runs/
*.mp4
*.safetensors
*.pt
*.onnx

# Great Expectations local uncommitted bits
gx/uncommitted/
