# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv
.DS_Store

# Caches / coverage
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Env / secrets
.env

# Logs
*.log

# nuScenes raw data is read from /data/ggare/datasets/nuscenes — never vendored.
/data/raw/*
!/data/raw/.gitkeep
# Produced Parquet is compute output on this GPU server; it is rsynced to the infra
# machine and DVC-tracked there — never git-committed from here. The *.dvc pointer files
# (created on the infra machine by `dvc add`) ARE committed.
/data/processed/*.parquet
!/data/processed/*.dvc

# ML / training artifacts (generated, large binaries)
mlruns/
mlartifacts/
wandb/
runs/
weights/
.cache/
/data/processed/yolo/
# Ultralytics training outputs when W&B is on (dir name == W&B project name)
/nuscenes-data-engine/
*.mp4
*.safetensors
*.pt
*.onnx

# Great Expectations local uncommitted bits
gx/uncommitted/

# Demo sample frames (nuScenes imagery is non-commercial-licensed — never committed;
# populate per machine, see README "Serving").
app/samples/*
!app/samples/.gitkeep

# Serving-request drift capture (Phase 5)
/data/monitoring/

# Frame-embedding vector store (Phase 6a; built on the GPU server, rsynced here)
/data/lancedb/

# Auto-labeling state: sample, batch ids, raw results, labels, eval (Phase 6b)
/data/autolabel/

# Active-learning experiment state: split, failures, clusters, arms, results (Phase 6d)
/data/active_learning/

# Phase 6c dataset-chat query log
/data/chat/
